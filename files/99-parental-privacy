#!/bin/sh
# 99-parental-privacy
# Requires: OpenWrt 21.02+ with DSA
# VLAN path  — mac80211 drivers (ath9k/ath10k/ath11k/mt76): full VLAN isolation
# Bridge path — Broadcom brcmfmac (and any driver lacking mac80211 VLAN support):
#               separate br-kids bridge; wired isolation via dedicated LAN port(s)

INSTALL_DIR="/usr/share/parental-privacy"

# ── Driver detection — brcmfmac / bridge mode ─────────────────────────────────
# Returns 0 (true) if ANY radio uses the Broadcom brcmfmac driver, which does
# not support mac80211 VLAN tagging on a VAP.  In that case we fall back to a
# separate br-kids bridge instead of a VLAN subinterface on br-lan.
is_brcmfmac() {
    for radio in $(uci show wireless 2>/dev/null \
                   | grep '=wifi-device' \
                   | sed 's/=wifi-device//;s/wireless\.//'); do
        # Try the explicit phy= key first, then derive phyN from radioN
        phy=$(uci -q get wireless.${radio}.phy 2>/dev/null)
        [ -z "$phy" ] && phy="phy${radio#radio}"
        # Read driver name from sysfs — works on OpenWrt 21.02+
        driver=$(cat /sys/class/ieee80211/${phy}/device/driver/module/name 2>/dev/null)
        [ -z "$driver" ] && \
            driver=$(basename "$(readlink /sys/class/ieee80211/${phy}/device/driver 2>/dev/null)" 2>/dev/null)
        [ "$driver" = "brcmfmac" ] && return 0
    done
    return 1
}

# ── VLAN selection ────────────────────────────────────────────────────────────
# Pick the first unused VLAN ID from the preferred list.
# Checks both UCI bridge-vlan configs and live kernel VLAN interfaces so we
# never clash with an existing VLAN (e.g. IPTV, VoIP, guest networks).
pick_vlan() {
    # Preference order:
    #   28  — matches the 172.28.x.x subnet scheme (172.28.28.x), memorable and unused
    #   80–100 — high numbers, away from typical guest/IPTV/VoIP/CCTV range
    #   70–40  — mid-range, less common but approaching consumer VLAN territory
    #   30     — last of the round numbers before the common block
    #   15, 25 — obscure non-round numbers, unlikely to be in use
    for candidate in 28 80 90 100 70 60 50 40 30 15 25; do
        # Check UCI network config for any bridge-vlan using this ID
        if uci show network 2>/dev/null | grep -q "\.vlan='${candidate}'"; then
            continue
        fi
        # Check kernel for live <bridge>.<vlan> or vlan<id> interfaces
        if ip link show 2>/dev/null | grep -qE "\\.${candidate}[^0-9]|vlan${candidate}[^0-9]"; then
            continue
        fi
        # Check /proc/net/vlan/config if it exists (swconfig systems)
        if [ -f /proc/net/vlan/config ] && grep -q "[[:space:]]${candidate}[[:space:]]" /proc/net/vlan/config 2>/dev/null; then
            continue
        fi
        echo "$candidate"
        return
    done
    # All candidates are taken — this is an unusual network configuration.
    # Fail loudly rather than silently grabbing a likely-in-use VLAN.
    logger -t parental-privacy "FATAL: No free VLAN ID found (tried 28 80 90 100 70 60 50 40 30 15 25). Install aborted."
    exit 1
}

KIDS_VLAN=$(pick_vlan)
# Derive the kids subnet from the VLAN ID: 172.28.<vlan>.x
KIDS_IP="172.28.${KIDS_VLAN}.1"

# Derive the LAN bridge name from UCI rather than assuming br-lan.
# Falls back to br-lan if the key is absent or not a bridge device.
_lan_dev=$(uci -q get network.lan.device 2>/dev/null)
case "$_lan_dev" in
    br-*)  LAN_BRIDGE="$_lan_dev" ;;
    *)     LAN_BRIDGE="br-lan"    ;;
esac

logger -t parental-privacy "Using VLAN ${KIDS_VLAN} (subnet 172.28.${KIDS_VLAN}.0/24)"

# ── Pre-install backup ────────────────────────────────────────────────────────
# Snapshot every UCI config we are about to touch, plus crontab and dnsmasq,
# so the user has a clean restore path if anything goes wrong.
# Backup lives at /etc/parental-privacy/pre-install-backup/<timestamp>/
# and includes a ready-to-run restore.sh that needs no extra tools.
_TS=$(date +%Y%m%d-%H%M%S)
_BACKUP_ROOT="/etc/parental-privacy/pre-install-backup"
_BACKUP_DIR="${_BACKUP_ROOT}/${_TS}"
mkdir -p "$_BACKUP_DIR"

# Export the four UCI configs we will modify
for _cfg in network wireless dhcp firewall; do
    uci export "$_cfg" > "${_BACKUP_DIR}/${_cfg}.uci" 2>/dev/null
done

# Snapshot crontab
[ -f /etc/crontabs/root ] && \
    cp /etc/crontabs/root "${_BACKUP_DIR}/crontab.root" 2>/dev/null

# Snapshot dnsmasq includes directory (SafeSearch writes here)
[ -d /etc/dnsmasq.d ] && \
    cp -r /etc/dnsmasq.d "${_BACKUP_DIR}/dnsmasq.d" 2>/dev/null

# Write a self-contained restore script into the backup directory
cat > "${_BACKUP_DIR}/restore.sh" << 'RESTORE_EOF'
#!/bin/sh
# Auto-generated by parental-privacy installer
# Run this script to fully revert to the state before parental-privacy was installed.
# Usage:  sh /etc/parental-privacy/pre-install-backup/<timestamp>/restore.sh

set -e
SELF_DIR="$(cd "$(dirname "$0")" && pwd)"

echo "==> Stopping parental-privacy services..."
[ -f /etc/init.d/parental-privacy ] && {
    /etc/init.d/parental-privacy stop  2>/dev/null || true
    /etc/init.d/parental-privacy disable 2>/dev/null || true
}

echo "==> Restoring UCI configs..."
for cfg in network wireless dhcp firewall; do
    backup="${SELF_DIR}/${cfg}.uci"
    [ -f "$backup" ] || { echo "  SKIP: ${cfg}.uci not found"; continue; }
    # Wipe current config then import the snapshot
    uci revert "$cfg" 2>/dev/null || true
    # uci import replaces all sections in the package
    uci import "$cfg" < "$backup"
    uci commit "$cfg"
    echo "  OK: $cfg"
done

echo "==> Restoring crontab..."
if [ -f "${SELF_DIR}/crontab.root" ]; then
    cp "${SELF_DIR}/crontab.root" /etc/crontabs/root
    /etc/init.d/cron restart 2>/dev/null || true
    echo "  OK: crontab"
else
    echo "  SKIP: no crontab backup"
fi

echo "==> Restoring dnsmasq includes..."
if [ -d "${SELF_DIR}/dnsmasq.d" ]; then
    rm -rf /etc/dnsmasq.d
    cp -r "${SELF_DIR}/dnsmasq.d" /etc/dnsmasq.d
    echo "  OK: dnsmasq.d"
else
    echo "  SKIP: no dnsmasq.d backup"
fi

echo "==> Removing parental-privacy UCI config..."
uci delete parental_privacy.default 2>/dev/null || true
uci commit parental_privacy 2>/dev/null || true

echo "==> Removing parental-privacy runtime files..."
rm -f /etc/dnsmasq.d/safesearch.conf 2>/dev/null || true

echo "==> Reloading services..."
/etc/init.d/network restart
/etc/init.d/dnsmasq restart
/etc/init.d/firewall restart
wifi reload >/dev/null 2>&1 &

echo ""
echo "Restore complete. Your router configuration has been returned to the"
echo "state it was in before parental-privacy was installed."
echo "Backup source: ${SELF_DIR}"
RESTORE_EOF
chmod +x "${_BACKUP_DIR}/restore.sh"

# Keep only the 3 most recent backups to avoid filling flash storage
# (each backup is typically 20-60 KB; 3 costs ~180 KB at most)
if [ -d "$_BACKUP_ROOT" ]; then
    ls -dt "${_BACKUP_ROOT}"/20* 2>/dev/null | tail -n +4 | while read -r _old; do
        rm -rf "$_old"
        logger -t parental-privacy "Pruned old backup: $_old"
    done
fi

logger -t parental-privacy "Pre-install backup saved to ${_BACKUP_DIR}"

# ── Choose install mode ───────────────────────────────────────────────────────
# BRIDGE_MODE=1 when brcmfmac is present OR when DSA/br-lan is unavailable.
# In bridge mode we create br-kids and skip the VLAN subinterface entirely.
BRIDGE_MODE=0

if ! ip link show br-lan >/dev/null 2>&1; then
    logger -t parental-privacy "br-lan not found — falling back to bridge mode."
    BRIDGE_MODE=1
elif [ -d /sys/class/net/br-lan/brif ] && \
     ls /sys/class/net/br-lan/brif/ | grep -q "eth" && \
     [ -f /proc/net/vlan/config ]; then
    logger -t parental-privacy "swconfig detected — falling back to bridge mode."
    BRIDGE_MODE=1
elif is_brcmfmac; then
    logger -t parental-privacy "brcmfmac driver detected — falling back to bridge mode (no mac80211 VLAN support)."
    BRIDGE_MODE=1
fi

uci set parental_privacy.default.bridge_mode="$BRIDGE_MODE"

# ── Initial Schedule ─────────────────────────────────────────────────────────
uci -q batch <<'EOF'
set parental_privacy.default=config
EOF
# Persist the chosen VLAN so scripts can read it at runtime
uci set parental_privacy.default.vlan_id="$KIDS_VLAN"
# Client isolation off by default — most families want kids devices to reach
# the Chromecast/printer on the kids VLAN, and broadcast relay handles
# cross-VLAN discovery anyway.  Power users can enable it from the dashboard.
# Broadcast relay on by default — enables Chromecast, AirPlay, printers,
# Steam and Minecraft LAN discovery between the kids VLAN and main LAN.
uci set parental_privacy.default.broadcast_relay="1"
for day in Mon Tue Wed Thu Sun; do
    uci set parental_privacy.default.schedule_$day='06:00-20:00'
done
for day in Fri Sat; do
    uci set parental_privacy.default.schedule_$day='06:00-21:00'
done
uci commit parental_privacy

# ── Default blocklist selections ──────────────────────────────────────────────
# Write the initial enabled/disabled state for every list in the catalog.
# These are written once at install time.  After this point, the user's
# selections are their own — update-blocklists.sh will update metadata
# (url, size_hint, name) when new lists appear but will never flip enabled.
#
# To change the defaults, edit the two lists below before running the installer.
#
#   BLOCKLIST_DEFAULTS  — enabled=1 on a fresh install
#   BLOCKLIST_DISABLED  — explicitly disabled (all other IDs also default to 0,
#                         but listing them here makes intent clear)

BLOCKLIST_DEFAULTS="hagezi_pro hagezi_tif hagezi_nsfw hagezi_gambling hagezi_rebind oisd_big"

# Only write defaults if no blocklist sections exist yet (i.e. truly fresh install,
# not a re-run or upgrade).  This preserves any selections the user has already made.
_bl_exists=$(uci show parental_privacy 2>/dev/null | grep -c "=blocklist")
if [ "$_bl_exists" -eq 0 ]; then
    logger -t parental-privacy "Writing default blocklist selections..."

    CATALOG_FILE="/usr/share/parental-privacy/blocklists.json"

    # If the catalog JSON is already present (bundled with the package), seed UCI
    # from it now so the dashboard shows real list names immediately — before the
    # first nightly update-blocklists.sh run at 03:00.
    if [ -f "$CATALOG_FILE" ] && grep -q '"id"' "$CATALOG_FILE" 2>/dev/null; then
        awk '
        /\{/            { id=""; name=""; url=""; size_hint="small"; desc="" }
        /"id"/          { match($0,/"id"[[:space:]]*:[[:space:]]*"([^"]+)"/,a); id=a[1] }
        /"name"/        { match($0,/"name"[[:space:]]*:[[:space:]]*"([^"]+)"/,a); name=a[1] }
        /"url"/         { match($0,/"url"[[:space:]]*:[[:space:]]*"([^"]+)"/,a); url=a[1] }
        /"size_hint"/   { match($0,/"size_hint"[[:space:]]*:[[:space:]]*"([^"]+)"/,a); size_hint=a[1] }
        /"description"/ { match($0,/"description"[[:space:]]*:[[:space:]]*"([^"]+)"/,a); desc=a[1] }
        /\}/            { if (id != "") print id "|" url "|" size_hint "|" name "|" desc }
        ' "$CATALOG_FILE" | while IFS='|' read -r c_id c_url c_size c_name c_desc; do
            [ -z "$c_id" ] && continue
            UCI_SECTION="blocklist_${c_id}"

            # Is this id in the defaults list?
            _enabled=0
            for _def in $BLOCKLIST_DEFAULTS; do
                [ "$_def" = "$c_id" ] && _enabled=1 && break
            done

            uci -q batch <<EOI
set parental_privacy.${UCI_SECTION}=blocklist
set parental_privacy.${UCI_SECTION}.id='${c_id}'
set parental_privacy.${UCI_SECTION}.name='${c_name}'
set parental_privacy.${UCI_SECTION}.url='${c_url}'
set parental_privacy.${UCI_SECTION}.size_hint='${c_size}'
set parental_privacy.${UCI_SECTION}.description='${c_desc}'
set parental_privacy.${UCI_SECTION}.enabled='${_enabled}'
EOI
        done
        uci commit parental_privacy
        logger -t parental-privacy "Blocklist defaults written from bundled catalog (enabled: ${BLOCKLIST_DEFAULTS})."
    else
        # Catalog not bundled yet — write just the default IDs as stubs.
        # update-blocklists.sh will fill in url/name/size_hint on first run.
        for _def in $BLOCKLIST_DEFAULTS; do
            uci -q batch <<EOI
set parental_privacy.blocklist_${_def}=blocklist
set parental_privacy.blocklist_${_def}.id='${_def}'
set parental_privacy.blocklist_${_def}.enabled='1'
EOI
        done
        uci commit parental_privacy
        logger -t parental-privacy "Blocklist stub defaults written (catalog not yet present — will be populated at 03:00)."
    fi
else
    logger -t parental-privacy "Blocklist selections already exist — skipping defaults."
fi

# ── Restore schedule from backup (if a previous install was removed) ──────────
# remove.sh writes /etc/parental-privacy/schedule.backup before wiping config.
# If that file exists we restore the saved values on top of the defaults above,
# then delete the backup so it isn't reused on a subsequent fresh install.
BACKUP_FILE="/etc/parental-privacy/schedule.backup"
if [ -f "$BACKUP_FILE" ]; then
    logger -t parental-privacy "Restoring schedule from $BACKUP_FILE"
    while IFS='=' read -r key val; do
        # Skip comment lines and blank lines
        case "$key" in '#'*|'') continue ;; esac
        case "$key" in
            schedule_Mon|schedule_Tue|schedule_Wed|schedule_Thu|\
            schedule_Fri|schedule_Sat|schedule_Sun)
                uci set parental_privacy.default.${key}="$val" ;;
            wifi_password)
                # Only restore password if none is set yet (fresh UCI)
                uci -q get parental_privacy.default.wifi_password >/dev/null 2>&1 || \
                    uci set parental_privacy.default.wifi_password="$val" ;;
        esac
    done < "$BACKUP_FILE"
    uci commit parental_privacy
    rm -f "$BACKUP_FILE"
    logger -t parental-privacy "Schedule restored and backup removed."
fi

# ── Random Password (generated once at install, before any UCI writes) ────────
# Falls back through three methods: openssl, /dev/urandom+tr, date hash.
# The password is stored in the parental_privacy UCI config so the dashboard
# and wizard can display / pre-fill it without re-reading the wireless config.
if ! uci -q get parental_privacy.default.wifi_password >/dev/null 2>&1; then
    if command -v openssl >/dev/null 2>&1; then
        KIDS_PASS=$(openssl rand -base64 12 | tr -dc 'A-Za-z0-9' | head -c 12)
    else
        KIDS_PASS=$(cat /dev/urandom | tr -dc 'A-Za-z0-9' 2>/dev/null | head -c 12)
    fi
    # Guarantee minimum length even if entropy source was thin
    [ ${#KIDS_PASS} -lt 8 ] && KIDS_PASS="Kids$(date +%s | tail -c 6)!"
    uci set parental_privacy.default.wifi_password="$KIDS_PASS"
    uci commit parental_privacy
else
    KIDS_PASS=$(uci get parental_privacy.default.wifi_password)
fi

# ── Dynamic SSID ─────────────────────────────────────────────────────────────
# Find the primary (main home) network SSID by scanning all wifi-iface sections
# and skipping any that are: already the kids VAP, disabled, a guest/IoT/kids
# network (by name heuristic), or not in AP mode.
# Falls back to @wifi-iface[0] if nothing suitable is found.
pick_primary_ssid() {
    local iface ssid mode network disabled found_ssid=""

    # Collect all named and indexed wifi-iface sections
    local iface_list
    iface_list=$(uci show wireless 2>/dev/null \
        | grep "=wifi-iface" \
        | sed "s/=wifi-iface//;s/wireless\.//" )

    for iface in $iface_list; do
        # Skip the kids VAPs we create (or may have created on a prior run)
        case "$iface" in kids_wifi*) continue ;; esac

        mode=$(uci -q get wireless.${iface}.mode)
        [ "$mode" != "ap" ] && continue

        disabled=$(uci -q get wireless.${iface}.disabled)
        [ "$disabled" = "1" ] && continue

        ssid=$(uci -q get wireless.${iface}.ssid 2>/dev/null)
        [ -z "$ssid" ] && continue

        # Skip SSIDs that look like guest / IoT / kids networks
        # (case-insensitive match on common suffixes/keywords)
        echo "$ssid" | grep -qiE \
            'guest|kids|child|iot|visitor|corp|office|_kids$|_guest$' \
            && continue

        # First surviving candidate wins
        found_ssid="$ssid"
        break
    done

    # Fallback: try @wifi-iface[0] regardless of type
    if [ -z "$found_ssid" ]; then
        found_ssid=$(uci -q get wireless.@wifi-iface[0].ssid 2>/dev/null)
    fi

    echo "${found_ssid:-OpenWrt}"
}

PRIMARY_SSID=$(pick_primary_ssid)
KIDS_SSID="${PRIMARY_SSID}_Kids"

# ── 1. Network interface — VLAN or bridge ────────────────────────────────────
if [ "$BRIDGE_MODE" = "1" ]; then
    # ── Bridge path ───────────────────────────────────────────────────────────
    # Create a standalone br-kids bridge.  The WiFi VAP attaches directly to it.
    # Wired isolation requires the user to assign physical LAN ports via the
    # dashboard — prompted by the UI warning banner.
    if ! uci get network.kids >/dev/null 2>&1; then
        uci set network.kids=interface
        uci set network.kids.type='bridge'
        uci set network.kids.proto='static'
        uci set network.kids.ipaddr="$KIDS_IP"
        uci set network.kids.netmask='255.255.255.0'
        # br-kids starts with no physical ports — user assigns them from the dashboard
    fi
    logger -t parental-privacy "Bridge mode: kids interface on br-kids (subnet 172.28.${KIDS_VLAN}.0/24)"
else
    # ── VLAN path ─────────────────────────────────────────────────────────────
    # Tag VLAN on br-lan; WiFi VAP attaches via VLAN subinterface.
    if ! uci get network.kids_vlan >/dev/null 2>&1; then
        uci set network.kids_vlan=bridge-vlan
        uci set network.kids_vlan.device="$LAN_BRIDGE"
        uci set network.kids_vlan.vlan="$KIDS_VLAN"

        for port in $(bridge link show | grep "master ${LAN_BRIDGE}" | awk '{print $2}' | tr -d ':' | grep -v '^cpu\|^eth0$'); do
            uci add_list network.kids_vlan.ports="${port}:t"
        done
    fi

    if ! uci get network.kids >/dev/null 2>&1; then
        uci set network.kids=interface
        uci set network.kids.device="${LAN_BRIDGE}.${KIDS_VLAN}"
        uci set network.kids.proto='static'
        uci set network.kids.ipaddr="$KIDS_IP"
        uci set network.kids.netmask='255.255.255.0'
    fi
    logger -t parental-privacy "VLAN mode: kids interface on ${LAN_BRIDGE}.${KIDS_VLAN} (subnet 172.28.${KIDS_VLAN}.0/24)"
fi

# ── 3. DHCP ──────────────────────────────────────────────────────────────────
if ! uci get dhcp.kids >/dev/null 2>&1; then
    uci set dhcp.kids=dhcp
    uci set dhcp.kids.interface='kids'
    uci set dhcp.kids.start='100'
    uci set dhcp.kids.limit='150'
    uci set dhcp.kids.leasetime='1h'
    uci add_list dhcp.kids.dhcp_option="3,${KIDS_IP}"
    uci add_list dhcp.kids.dhcp_option="6,1.1.1.3,1.0.0.3"
fi

# ── 3a. Kids dnsmasq confdir ──────────────────────────────────────────────────
# The kids dnsmasq instance (dhcp.kids_dns) must have confdir set to
# /etc/dnsmasq.kids.d so it automatically picks up blocklist files without
# any per-file configuration.  We set it here at install time and also in
# rpc-blocklist.sh so it is always correct even if the wizard ran first.
mkdir -p /etc/dnsmasq.kids.d
if uci get dhcp.kids_dns >/dev/null 2>&1; then
    EXISTING_CONFDIR=$(uci -q get dhcp.kids_dns.confdir 2>/dev/null)
    if [ "$EXISTING_CONFDIR" != "/etc/dnsmasq.kids.d" ]; then
        uci set dhcp.kids_dns.confdir='/etc/dnsmasq.kids.d'
        logger -t parental-privacy "Set kids dnsmasq confdir to /etc/dnsmasq.kids.d"
    fi
fi

# ── 3b. Kids dnsmasq DNS query logging (RAM-only, privacy-safe) ───────────────
# Direct query logs to a dedicated RAM file — NOT the system syslog — so that
# high-volume DNS queries never pollute logread output.  The file lives in
# /tmp/ (tmpfs) so it is wiped automatically on every reboot.  The dashboard
# polls rpc-get-logs and keeps only the last 50 entries in the UI.
#
# option logfacility  → dnsmasq writes directly to this file (not syslog)
# option logqueries   → emit a query[] line for every DNS lookup
#
# We only set these when the kids_dns instance exists and the values are not
# already correct, so repeated runs of this script are idempotent.
if uci get dhcp.kids_dns >/dev/null 2>&1; then
    EXISTING_LOGFAC=$(uci -q get dhcp.kids_dns.logfacility 2>/dev/null)
    if [ "$EXISTING_LOGFAC" != "/tmp/dnsmasq-kids.log" ]; then
        uci set dhcp.kids_dns.logfacility='/tmp/dnsmasq-kids.log'
        logger -t parental-privacy "Set kids dnsmasq logfacility to /tmp/dnsmasq-kids.log"
    fi

    EXISTING_LOGQ=$(uci -q get dhcp.kids_dns.logqueries 2>/dev/null)
    if [ "$EXISTING_LOGQ" != "1" ]; then
        uci set dhcp.kids_dns.logqueries='1'
        logger -t parental-privacy "Enabled kids dnsmasq log-queries"
    fi
fi

# ── 4. Firewall ──────────────────────────────────────────────────────────────
if ! uci get firewall.kids_zone >/dev/null 2>&1; then
    # Zone — no masq required, WAN zone handles NAT for all routed traffic
    uci set firewall.kids_zone=zone
    uci set firewall.kids_zone.name='kids'
    uci set firewall.kids_zone.network='kids'
    uci set firewall.kids_zone.input='REJECT'
	uci set firewall.kids_zone.forward='ACCEPT'
    uci set firewall.kids_zone.output='ACCEPT'

    # Allow DHCP
    uci set firewall.kids_dhcp=rule
    uci set firewall.kids_dhcp.name='Allow-Kids-DHCP'
    uci set firewall.kids_dhcp.src='kids'
    uci set firewall.kids_dhcp.proto='udp'
    uci set firewall.kids_dhcp.dest_port='67'
    uci set firewall.kids_dhcp.target='ACCEPT'

	# Explicitly block SSH to the router
	uci set firewall.kids_block_ssh_router=rule
	uci set firewall.kids_block_ssh_router.name='Block-Kids-SSH-Router'
	uci set firewall.kids_block_ssh_router.src='kids'
	uci set firewall.kids_block_ssh_router.dest_port='22'
	uci set firewall.kids_block_ssh_router.proto='tcp'
	uci set firewall.kids_block_ssh_router.target='REJECT'

	# Block HTTP/HTTPS access to the router management interface
	uci set firewall.kids_block_web_ui=rule
	uci set firewall.kids_block_web_ui.name='Block-Kids-Router-WebUI'
	uci set firewall.kids_block_web_ui.src='kids'
	uci set firewall.kids_block_web_ui.dest_port='80 443'
	uci set firewall.kids_block_web_ui.proto='tcp'
	uci set firewall.kids_block_web_ui.target='REJECT'

	# Explicitly block SSH to the internet
	uci set firewall.kids_block_ssh_wan=rule
	uci set firewall.kids_block_ssh_wan.name='Block-Kids-SSH-WAN'
	uci set firewall.kids_block_ssh_wan.src='kids'
	uci set firewall.kids_block_ssh_wan.dest='wan'
	uci set firewall.kids_block_ssh_wan.dest_port='22'
	uci set firewall.kids_block_ssh_wan.proto='tcp'
	uci set firewall.kids_block_ssh_wan.target='REJECT'

	# Explicitly block SSH to the Lan
	uci set firewall.kids_block_ssh_lan=rule
	uci set firewall.kids_block_ssh_lan.name='Block-Kids-SSH-to-MainLAN'
	uci set firewall.kids_block_ssh_lan.src='kids'
	uci set firewall.kids_block_ssh_lan.dest='lan'
	uci set firewall.kids_block_ssh_lan.dest_port='22'
	uci set firewall.kids_block_ssh_lan.proto='tcp'
	uci set firewall.kids_block_ssh_lan.target='REJECT'

	# Explicitly block SSH to the kids
	uci set firewall.kids_block_ssh_internal=rule
	uci set firewall.kids_block_ssh_internal.name='Block-Kids-Internal-SSH'
	uci set firewall.kids_block_ssh_internal.src='kids'
	uci set firewall.kids_block_ssh_internal.dest='kids'
	uci set firewall.kids_block_ssh_internal.dest_port='22'
	uci set firewall.kids_block_ssh_internal.proto='tcp'
	uci set firewall.kids_block_ssh_internal.target='REJECT'

    # Allow DNS to router
    uci set firewall.kids_dns=rule
    uci set firewall.kids_dns.name='Allow-Kids-DNS'
    uci set firewall.kids_dns.src='kids'
    uci set firewall.kids_dns.proto='tcp udp'
    uci set firewall.kids_dns.dest_port='53'
    uci set firewall.kids_dns.target='ACCEPT'

    # Intercept DNS bypass attempts
    uci set firewall.kids_dns_intercept=redirect
    uci set firewall.kids_dns_intercept.name='Intercept-Kids-DNS'
    uci set firewall.kids_dns_intercept.src='kids'
    uci set firewall.kids_dns_intercept.src_dport='53'
    uci set firewall.kids_dns_intercept.dest_port='53'
    uci set firewall.kids_dns_intercept.proto='tcp udp'
    uci set firewall.kids_dns_intercept.target='DNAT'

    # Intercept any IPv6 DNS not aimed at the router and redirect it back
    uci set firewall.kids_dns_intercept6=redirect
    uci set firewall.kids_dns_intercept6.name='Intercept-Kids-DNS6'
    uci set firewall.kids_dns_intercept6.src='kids'
    uci set firewall.kids_dns_intercept6.src_dport='53'
    uci set firewall.kids_dns_intercept6.dest_port='53'
    uci set firewall.kids_dns_intercept6.proto='tcp udp'
    uci set firewall.kids_dns_intercept6.target='DNAT'
    uci set firewall.kids_dns_intercept6.family='ipv6'

    # Allow ICMP
    uci set firewall.kids_icmp=rule
    uci set firewall.kids_icmp.name='Allow-Kids-ICMP'
    uci set firewall.kids_icmp.src='kids'
    uci set firewall.kids_icmp.proto='icmp'
    uci set firewall.kids_icmp.target='ACCEPT'

    # Forward kids → WAN only
    uci set firewall.kids_forward=forwarding
    uci set firewall.kids_forward.src='kids'
    uci set firewall.kids_forward.dest='wan'

    # UPnP input rule — allows miniupnpd to respond to consoles on this zone.
    # Without this, consoles get NAT Type 3 (Strict) even on a single-NAT setup.
    uci set firewall.kids_upnp=rule
    uci set firewall.kids_upnp.name='Allow-Kids-UPnP'
    uci set firewall.kids_upnp.src='kids'
    uci set firewall.kids_upnp.proto='udp'
    uci set firewall.kids_upnp.dest_port='1900'
    uci set firewall.kids_upnp.target='ACCEPT'
	
	# 1. Allow Main LAN to reach Kids (Adults to Kids)
	# This allows you to manage their devices or send files to them.
	uci set firewall.lan_to_kids=forwarding
	uci set firewall.lan_to_kids.src='lan'
	uci set firewall.lan_to_kids.dest='kids'

	# 2. Allow Kids to reach Main LAN (Kids to Adults)
	# This allows them to use printers and join LAN games on your PC.
	uci set firewall.kids_to_lan=forwarding
	uci set firewall.kids_to_lan.src='kids'
	uci set firewall.kids_to_lan.dest='lan'
	
fi

# ── 5. Wireless ──────────────────────────────────────────────────────────────
# VLAN path:   network='kids' → br-lan.<vlan>  (mac80211 handles VLAN tagging)
# Bridge path: network='kids' → br-kids        (no VLAN tagging needed)

# Radio detection: prefer the OpenWrt 22.03+ 'band=' key; fall back to
# 'hwmode=' for 21.02 compatibility.  hwmode='11g' = 2.4GHz only.
# hwmode='11a' is ambiguous (used for 5GHz a/n/ac/ax) so we match band='5g'
# first, then fall back to hwmode='11a' only if band= is absent.

# 2.4 GHz
RADIO_2G=$(uci show wireless | grep "band='2g'" | head -n1 | cut -d. -f2)
[ -z "$RADIO_2G" ] && RADIO_2G=$(uci show wireless | grep "hwmode='11g'" | head -n1 | cut -d. -f2)
[ -z "$RADIO_2G" ] && RADIO_2G="radio0"
if ! uci get wireless.kids_wifi >/dev/null 2>&1; then
    uci set wireless.kids_wifi=wifi-iface
    uci set wireless.kids_wifi.device="$RADIO_2G"
    uci set wireless.kids_wifi.network='kids'
    uci set wireless.kids_wifi.mode='ap'
    uci set wireless.kids_wifi.ssid="$KIDS_SSID"
    uci set wireless.kids_wifi.encryption='psk2'
    uci set wireless.kids_wifi.key="$KIDS_PASS"
    uci set wireless.kids_wifi.disabled='1'
fi

# 5 GHz (if present)
RADIO_5G=$(uci show wireless | grep "band='5g'" | head -n1 | cut -d. -f2)
[ -z "$RADIO_5G" ] && RADIO_5G=$(uci show wireless | grep "hwmode='11a'" | head -n1 | cut -d. -f2)
if [ -n "$RADIO_5G" ]; then
    if ! uci get wireless.kids_wifi_5g >/dev/null 2>&1; then
        uci set wireless.kids_wifi_5g=wifi-iface
        uci set wireless.kids_wifi_5g.device="$RADIO_5G"
        uci set wireless.kids_wifi_5g.network='kids'
        uci set wireless.kids_wifi_5g.mode='ap'
        uci set wireless.kids_wifi_5g.ssid="$KIDS_SSID"
        uci set wireless.kids_wifi_5g.encryption='psk2'
        uci set wireless.kids_wifi_5g.key="$KIDS_PASS"
        uci set wireless.kids_wifi_5g.disabled='1'
    fi
fi

# 6 GHz (if present — requires WPA3/SAE)
RADIO_6G=$(uci show wireless | grep -E "band='6g'" | head -n1 | cut -d. -f2)
if [ -n "$RADIO_6G" ]; then
    if ! uci get wireless.kids_wifi_6g >/dev/null 2>&1; then
        uci set wireless.kids_wifi_6g=wifi-iface
        uci set wireless.kids_wifi_6g.device="$RADIO_6G"
        uci set wireless.kids_wifi_6g.network='kids'
        uci set wireless.kids_wifi_6g.mode='ap'
        uci set wireless.kids_wifi_6g.ssid="$KIDS_SSID"
        uci set wireless.kids_wifi_6g.encryption='sae'
        uci set wireless.kids_wifi_6g.key="$KIDS_PASS"
        uci set wireless.kids_wifi_6g.disabled='1'
    fi
fi

# ── SafeSearch (default on) ──────────────────────────────────────────────────
/usr/share/parental-privacy/safesearch.sh enable

# ── Commit & Restart ─────────────────────────────────────────────────────────
/etc/init.d/parental-privacy enable
uci commit network
uci commit dhcp
uci commit firewall
uci commit wireless

# Bring up the network first — creates br-lan.<vlan> and the kids interface.
/etc/init.d/network restart

# Wait for the kids interface to be fully ready before starting dependent
# services.  Two-phase check:
#
#   Phase 1 — ubus wait_for network.interface.kids
#     Blocks until netifd has registered the interface object, confirming
#     the network subsystem knows about it.  30-second timeout.
#
#   Phase 2 — ip addr show polling loop
#     netifd fires the ubus event as soon as the netlink RTM_NEWADDR message
#     arrives, but on some DSA/VLAN hardware the kernel assigns the address
#     fractionally before the bridge FDB and VLAN filter tables have converged.
#     dnsmasq bind() issued at that instant gets EADDRNOTAVAIL.  We poll
#     until 'ip addr show' confirms the kids IP is actually reachable — this
#     is a kernel-space guarantee rather than a timing guess.
#
#   Falls back to a plain sleep if ubus itself is not yet ready (rare during
#   early first-boot where rc.local runs before ubusd is fully initialised).

KIDS_IP_WAIT=$(uci -q get network.kids.ipaddr)
KIDS_IP_WAIT=${KIDS_IP_WAIT:-172.28.${KIDS_VLAN}.1}

if ! ubus wait_for network.interface.kids 2>/dev/null; then
    logger -t parental-privacy "ubus wait_for timed out — falling back to sleep"
    sleep 8
fi

# Phase 2: poll until the IP address is visible in the kernel's interface list.
# Max 20 attempts × 1 second = 20-second ceiling; typical convergence is <3s.
_iface_ready=0
for _attempt in $(seq 1 20); do
    if ip addr show 2>/dev/null | grep -qF "${KIDS_IP_WAIT}"; then
        _iface_ready=1
        logger -t parental-privacy "Kids interface IP ready after ${_attempt}s"
        break
    fi
    sleep 1
done

if [ "$_iface_ready" = "0" ]; then
    logger -t parental-privacy "WARNING: kids IP ${KIDS_IP_WAIT} not visible after 20s — dnsmasq may fail to bind. Check bridge/VLAN state."
fi

# dnsmasq: restart (not reload) so it picks up the new kids DHCP pool and
# binds fresh on the kids interface IP.
/etc/init.d/dnsmasq restart

# firewall: restart so fw4 rebuilds all chains including the new kids zone.
# reload is not sufficient — the zone didn't exist before this script ran.
/etc/init.d/firewall restart

# WiFi: backgrounded — VAPs come up asynchronously, no need to block here.
# The VAPs start disabled so no clients connect until the wizard enables them.
wifi reload >/dev/null 2>&1 &

# parental-privacy: start after dnsmasq and firewall are ready, since the
# init script applies SafeSearch (dnsmasq) and DoH blocking (nftables).
/etc/init.d/parental-privacy start

logger -t parental-privacy "Setup complete ($([ "$BRIDGE_MODE" = "1" ] && echo "bridge mode" || echo "VLAN mode")). Service parental-privacy is now active."

exit 0
